# Database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/opensource_mentor

# Cognee Cloud
COGNEE_API_URL=https://your-tenant.aws.cognee.ai
COGNEE_API_KEY=your-cognee-api-key

# GitHub
GITHUB_TOKEN=ghp_your-github-personal-access-token

# LLM (openai, gemini, groq, or openrouter)
LLM_PROVIDER=openai
OPENAI_API_KEY=sk-your-openai-api-key
GEMINI_API_KEY=your-gemini-api-key
GROQ_API_KEY=gsk_your-groq-api-key
OPENROUTER_API_KEY=sk-or-your-openrouter-api-key

# LLM_INGESTION_PROVIDER and LLM_QUERY_PROVIDER accept:
#   gemini | openai | groq | openrouter
LLM_INGESTION_PROVIDER=openai
LLM_INGESTION_MODEL=gpt-4o-mini
LLM_QUERY_PROVIDER=gemini
LLM_QUERY_MODEL=gemini-2.5-flash

# Auth
JWT_SECRET_KEY=your-jwt-secret-change-this
FRONTEND_URL=http://localhost:3000
